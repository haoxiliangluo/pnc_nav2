<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="wpr_nav">

  <!--
    WPR (启智) 机器人导航配置
    在 wpr_simulation2 基础上添加 Mid360 LiDAR

    依赖: wpr_simulation2 包
    官方仓库: https://github.com/6-robot/wpr_simulation2
  -->

  <xacro:include filename="$(find pnc_nav_simulation)/urdf/sensors/livox_mid360.urdf.xacro"/>
  <xacro:include filename="$(find pnc_nav_simulation)/urdf/sensors/imu.urdf.xacro"/>

  <!--
    TODO: Include official WPR description
    <xacro:include filename="$(find wpr_simulation2)/urdf/wpr.urdf.xacro"/>
  -->

  <!-- 临时占位：简化的 WPR 模型（圆柱体底盘） -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.2" length="0.4"/>
      </geometry>
      <material name="white">
        <color rgba="0.9 0.9 0.9 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.2" length="0.4"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="20.0"/>
      <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.5" iyz="0" izz="0.4"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
  </joint>

  <!-- 头部（传感器安装平台） -->
  <link name="sensor_mount">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.05"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="sensor_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_mount"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
  </joint>

  <!-- 差速驱动 (WPR 是差速轮式机器人) -->
  <gazebo>
    <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.36</wheel_separation>
      <wheel_diameter>0.12</wheel_diameter>
      <max_wheel_torque>20.0</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <update_rate>50.0</update_rate>
    </plugin>
  </gazebo>

  <!-- 传感器：Livox Mid360 (安装在顶部) -->
  <xacro:livox_mid360
    parent_link="sensor_mount"
    xyz="0 0 0.05"
    rpy="0 0 0"
    topic="/livox/pointcloud"
    frame="livox_frame"/>

  <!-- 传感器：IMU -->
  <xacro:imu_sensor
    parent_link="base_link"
    xyz="0 0 0"
    rpy="0 0 0"
    topic="/imu"
    frame="imu_link"
    update_rate="200"/>

</robot>
