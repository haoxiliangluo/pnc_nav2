<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="livox_mid360">

  <!--
    Livox Mid360 LiDAR 传感器 Xacro 宏
    非重复扫描模式，360° FOV，40m量程
    使用 livox_laser_simulation_ros2 插件仿真
  -->

  <xacro:macro name="livox_mid360" params="parent_link:=base_link xyz:='0 0 0.2' rpy:='0 0 0' topic:=/livox/pointcloud frame:=livox_frame">

    <!-- Mid360 Link -->
    <link name="${frame}">
      <visual>
        <geometry>
          <cylinder radius="0.04" length="0.05"/>
        </geometry>
        <material name="dark_grey">
          <color rgba="0.3 0.3 0.3 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.04" length="0.05"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.265"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>

    <!-- Joint to parent -->
    <joint name="${frame}_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child link="${frame}"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <!-- Gazebo Livox Plugin -->
    <!--
      使用 livox_laser_simulation_ros2 插件
      如果该插件不可用，回退到标准 ray sensor
    -->
    <gazebo reference="${frame}">
      <sensor type="ray" name="livox_mid360">
        <pose>0 0 0 0 0 0</pose>
        <visualize>false</visualize>
        <update_rate>10</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
            <vertical>
              <samples>32</samples>
              <resolution>1</resolution>
              <min_angle>-0.1222</min_angle>
              <max_angle>0.9076</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.1</min>
            <max>40.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>
        <plugin name="gazebo_ros_livox" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <remapping>~/out:=${topic}</remapping>
          </ros>
          <output_type>sensor_msgs/PointCloud2</output_type>
          <frame_name>${frame}</frame_name>
          <min_intensity>0</min_intensity>
        </plugin>
      </sensor>
    </gazebo>

  </xacro:macro>

</robot>
