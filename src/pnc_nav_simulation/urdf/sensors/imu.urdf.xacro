<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="imu_sensor">

  <!--
    IMU 传感器 Xacro 宏
    6轴 IMU (加速度计 + 陀螺仪)
  -->

  <xacro:macro name="imu_sensor" params="parent_link:=base_link xyz:='0 0 0.1' rpy:='0 0 0' topic:=/imu frame:=imu_link update_rate:=200">

    <!-- IMU Link -->
    <link name="${frame}">
      <visual>
        <geometry>
          <box size="0.02 0.02 0.01"/>
        </geometry>
        <material name="blue">
          <color rgba="0.0 0.0 0.8 1.0"/>
        </material>
      </visual>
      <inertial>
        <mass value="0.01"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>

    <!-- Joint to parent -->
    <joint name="${frame}_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child link="${frame}"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <!-- Gazebo IMU Plugin -->
    <gazebo reference="${frame}">
      <sensor type="imu" name="imu_sensor">
        <always_on>true</always_on>
        <update_rate>${update_rate}</update_rate>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></z>
          </linear_acceleration>
        </imu>
        <plugin name="gazebo_ros_imu" filename="libgazebo_ros_imu_sensor.so">
          <ros>
            <remapping>~/out:=${topic}</remapping>
          </ros>
          <frame_name>${frame}</frame_name>
          <initial_orientation_as_reference>false</initial_orientation_as_reference>
        </plugin>
      </sensor>
    </gazebo>

  </xacro:macro>

</robot>
