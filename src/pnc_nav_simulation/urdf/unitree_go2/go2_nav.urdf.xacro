<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="unitree_go2_nav">

  <!--
    Unitree Go2 导航配置
    在官方 Go2 URDF 基础上添加 Mid360 LiDAR + IMU

    依赖: unitree_ros2 包中的 go2_description
    使用方式: 将此文件作为顶层 xacro，include 官方描述文件
  -->

  <!--
    注意：实际使用时需要 include 官方 Go2 URDF
    这里提供传感器挂载的模板

    官方仓库: https://github.com/unitreerobotics/unitree_ros2
    替代方案: https://github.com/Unitree-Go2-Robot/go2_robot
  -->

  <xacro:include filename="$(find pnc_nav_simulation)/urdf/sensors/livox_mid360.urdf.xacro"/>
  <xacro:include filename="$(find pnc_nav_simulation)/urdf/sensors/imu.urdf.xacro"/>

  <!--
    TODO: Include official Go2 description
    <xacro:include filename="$(find go2_description)/urdf/go2.urdf.xacro"/>
  -->

  <!-- 临时占位：简化的 Go2 机体模型（用于框架验证） -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.6 0.3 0.15"/>
      </geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.6 0.3 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="12.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.3" iyz="0" izz="0.35"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
  </joint>

  <!-- 四条腿的简化表示 -->
  <xacro:macro name="leg_placeholder" params="name x y">
    <link name="${name}_foot">
      <visual>
        <geometry><sphere radius="0.02"/></geometry>
        <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
      </visual>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>
    <joint name="${name}_foot_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}_foot"/>
      <origin xyz="${x} ${y} -0.3" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:leg_placeholder name="FL" x="0.2" y="0.15"/>
  <xacro:leg_placeholder name="FR" x="0.2" y="-0.15"/>
  <xacro:leg_placeholder name="RL" x="-0.2" y="0.15"/>
  <xacro:leg_placeholder name="RR" x="-0.2" y="-0.15"/>

  <!-- 传感器：Livox Mid360 (安装在背部) -->
  <xacro:livox_mid360
    parent_link="base_link"
    xyz="0 0 0.12"
    rpy="0 0 0"
    topic="/livox/pointcloud"
    frame="livox_frame"/>

  <!-- 传感器：IMU (机体中心) -->
  <xacro:imu_sensor
    parent_link="base_link"
    xyz="0 0 0"
    rpy="0 0 0"
    topic="/imu"
    frame="imu_link"
    update_rate="500"/>

  <!--
    Gazebo 控制插件
    Phase 1: 使用 planar_move 插件模拟全向移动（简化）
    Phase 4: 替换为 RL 步态控制器
  -->
  <gazebo>
    <plugin name="planar_move_controller" filename="libgazebo_ros_planar_move.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <update_rate>50.0</update_rate>
    </plugin>
  </gazebo>

</robot>
